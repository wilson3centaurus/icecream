{
  "name": "@absolute-ice-cream/database",
  "version": "0.1.0",
  "private": true,
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "files": ["dist", "prisma"],
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "db:generate:mysql": "prisma generate --schema prisma/schema.mysql.prisma",
    "db:generate:pg": "prisma generate --schema prisma/schema.postgresql.prisma",
    "db:migrate:mysql": "prisma migrate dev --schema prisma/schema.mysql.prisma",
    "db:migrate:pg": "prisma migrate dev --schema prisma/schema.postgresql.prisma",
    "db:deploy:supabase": "prisma migrate deploy --schema prisma/schema.postgresql.prisma",
    "db:push:mysql": "prisma db push --schema prisma/schema.mysql.prisma",
    "db:push:pg": "prisma db push --schema prisma/schema.postgresql.prisma",
    "db:seed:mysql": "prisma db seed --schema prisma/schema.mysql.prisma",
    "db:seed:pg": "prisma db seed --schema prisma/schema.postgresql.prisma",
    "db:studio:mysql": "prisma studio --schema prisma/schema.mysql.prisma",
    "db:studio:pg": "prisma studio --schema prisma/schema.postgresql.prisma",
    "generate": "prisma generate",
    "lint": "eslint src prisma/seed.ts --ext .ts",
    "seed": "tsx prisma/seed.ts",
    "seed:sample-accounts": "tsx prisma/seed-sample-accounts.ts",
    "seed:testing": "tsx prisma/seed-testing.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "prisma": "^6.19.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
