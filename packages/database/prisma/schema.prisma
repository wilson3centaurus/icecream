model BankReconciliation {
  id                  String     @id @default(uuid()) @db.Uuid
  organizationId      String     @db.Uuid @map("organization_id")
  bankAccountId       String     @db.Uuid @map("bank_account_id")
  periodStart         DateTime   @db.Date @map("period_start")
  periodEnd           DateTime   @db.Date @map("period_end")
  openingBalance      Decimal    @db.Decimal(18, 2) @map("opening_balance")
  closingBalance      Decimal    @db.Decimal(18, 2) @map("closing_balance")
