generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum SupplierStatus {
  ACTIVE
  INACTIVE
  BLACKLISTED
}

enum ItemType {
  RAW_MATERIAL
  PACKAGING_MATERIAL
  FINISHED_GOOD
  WORK_IN_PROGRESS
  CONSUMABLE
  SPARE_PART
}

enum StockMovementType {
  PURCHASE_RECEIVE
  PRODUCTION_ISSUE
  PRODUCTION_OUTPUT
  WIP_TRANSFER
  TRANSFER_OUT
  TRANSFER_IN
  SALES_ISSUE
  RETURN_IN
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  DAMAGE
  EXPIRY_WRITE_OFF
  WASTAGE
  SPILLAGE
  MACHINE_LOSS
  PACKAGING_LOSS
}

enum PurchaseRequisitionStatus {
  DRAFT
  SUBMITTED
  LEVEL1_APPROVED
  LEVEL2_APPROVED
  LEVEL3_APPROVED
  LEVEL4_APPROVED
  REJECTED
  CANCELLED
  PO_CREATED
}

enum PurchaseOrderStatus {
  DRAFT
  AWAITING_APPROVAL
  LEVEL1_APPROVED
  LEVEL2_APPROVED
  LEVEL3_APPROVED
  APPROVED
  SENT_TO_SUPPLIER
  PARTIAL_RECEIVED
  FULLY_RECEIVED
  CANCELLED
}

enum GRNStatus {
  DRAFT
  RECEIVED
  QUALITY_INSPECTION
  QUALITY_PASSED
  QUALITY_FAILED
  POSTED
  REJECTED
}

enum ProductionBatchStatus {
  DRAFT
  PLANNED
  MATERIALS_REQUESTED
  MATERIALS_APPROVED
  MATERIALS_RESERVED
  IN_PROGRESS
  WIP
  QUALITY_CHECK
  COMPLETED
  CANCELLED
}

enum QualityStatus {
  PENDING
  PASSED
  FAILED
  CONDITIONAL_RELEASE
  QUARANTINE
}

enum ShiftType {
  DAY
  NIGHT
}

enum BranchShiftStatus {
  OPEN
  SUBMITTED
  REVIEWED
  APPROVED
  REJECTED
}

enum SalesOrderStatus {
  DRAFT
  CONFIRMED
  CREDIT_CHECK
  PICKING
  DISPATCHED
  DELIVERED
  INVOICED
  PARTIALLY_PAID
  PAID
  CANCELLED
}

enum PaymentMethod {
  CASH
  ECOCASH
  CARD
  BANK_TRANSFER
  CREDIT
  PETTY_CASH
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIAL_PAID
  PAID
  OVERDUE
  DISPUTED
  CANCELLED
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  TERMINATED
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum MaintenanceStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  OVERDUE
  CANCELLED
}

enum MaintenanceType {
  PREVENTIVE
  CORRECTIVE
  BREAKDOWN
  INSPECTION
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  ESCALATED
}

enum ApprovalLevel {
  LEVEL1_SUPERVISOR
  LEVEL2_MANAGER
  LEVEL3_FINANCE_MANAGER
  LEVEL4_MANAGING_DIRECTOR
}

enum TransactionStatus {
  DRAFT
  POSTED
  APPROVED
  LOCKED
  VOIDED
}

enum BudgetStatus {
  DRAFT
  SUBMITTED
  APPROVED
  ACTIVE
  CLOSED
}

enum BranchStatus {
  ACTIVE
  INACTIVE
  CLOSED
}

enum WarehouseType {
  MAIN
  BRANCH
  COLD_ROOM
}

enum InventoryBatchStatus {
  ACTIVE
  EXPIRED
  DEPLETED
  QUARANTINE
}

enum TransferStatus {
  DRAFT
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

enum ReturnStatus {
  DRAFT
  APPROVED
  COMPLETED
  CANCELLED
}

enum RecipeStatus {
  DRAFT
  ACTIVE
  INACTIVE
}

enum ProductionPlanStatus {
  DRAFT
  APPROVED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
  BLACKLISTED
}

enum QuotationStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
  CANCELLED
}

enum DeliveryNoteStatus {
  DRAFT
  DISPATCHED
  DELIVERED
  CANCELLED
}

enum PayrollStatus {
  DRAFT
  APPROVED
  PAID
  CANCELLED
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
  COST_OF_SALES
}

enum WastageType {
  MATERIAL_WASTAGE
  PRODUCT_LOSS
  SPILLAGE
  MACHINE_LOSS
  PACKAGING_LOSS
  QUALITY_REJECTION
  EXPIRY_LOSS
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
  ACTION_REQUIRED
}

model Organization {
  id                  String                  @id @default(uuid()) @db.Uuid
  name                String
  logoUrl             String?                 @map("logo_url")
  address             String?
  phone               String?
  email               String?
  taxNumber           String?                 @map("tax_number")
  currency            String                  @default("USD")
  financialYearStart  Int                     @default(1) @map("financial_year_start")
  createdAt           DateTime                @default(now()) @map("created_at")
  updatedAt           DateTime                @updatedAt @map("updated_at")
  userProfiles        UserProfile[]
  userAccounts        UserAccount[]
  roles               Role[]
  branches            Branch[]
  warehouses          Warehouse[]
  itemCategories      ItemCategory[]
  unitsOfMeasure      UnitOfMeasure[]
  items               Item[]
  inventoryBatches    InventoryBatch[]
  stockBalances       StockBalance[]
  stockMovements      StockMovement[]
  stockTransfers      StockTransfer[]
  supplierCategories  SupplierCategory[]
  suppliers           Supplier[]
  purchaseRequisitions PurchaseRequisition[]
  purchaseOrders      PurchaseOrder[]
  goodsReceivedNotes  GoodsReceivedNote[]
  supplierReturns     SupplierReturn[]
  recipes             Recipe[]
  productionPlans     ProductionPlan[]
  productionBatches   ProductionBatch[]
  qualityChecks       QualityCheck[]
  customers           Customer[]
  quotations          Quotation[]
  salesOrders         SalesOrder[]
  deliveryNotes       DeliveryNote[]
  invoices            Invoice[]
  payments            Payment[]
  customerReturns     CustomerReturn[]
  branchSales         BranchSale[]
  branchExpenses      BranchExpense[]
  branchShiftCloses   BranchShiftClose[]
  employees           Employee[]
  attendances         Attendance[]
  payrollRecords      PayrollRecord[]
  accounts            Account[]
  journalEntries      JournalEntry[]
  documentFiles       DocumentFile[]
  notifications       Notification[]
  auditLogs           AuditLog[]

  @@index([name])
  @@map("organizations")
}

model UserProfile {
  id                   String         @id @default(uuid()) @db.Uuid
  clerkUserId          String         @unique @map("clerk_user_id")
  organizationId       String         @db.Uuid @map("organization_id")
  employeeId           String?        @unique @db.Uuid @map("employee_id")
  firstName            String         @map("first_name")
  lastName             String         @map("last_name")
  email                String
  phone                String?
  avatarUrl            String?        @map("avatar_url")
  status               UserStatus     @default(ACTIVE)
  branchId             String?        @db.Uuid @map("branch_id")
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")
  deletedAt            DateTime?      @map("deleted_at")
  organization         Organization   @relation(fields: [organizationId], references: [id])
  employee             Employee?      @relation("EmployeeUserProfile", fields: [employeeId], references: [id])
  branch               Branch?        @relation("BranchUsers", fields: [branchId], references: [id])
  managedBranches      Branch[]       @relation("BranchManager")
  roleAssignments      UserRole[]     @relation("UserRoleProfile")
  rolesAssigned        UserRole[]     @relation("UserRoleAssignedBy")
  createdSuppliers     Supplier[]     @relation("SupplierCreatedBy")
  requestedRequisitions PurchaseRequisition[] @relation("PurchaseRequisitionRequestedBy")
  approvedRequisitions PurchaseRequisition[] @relation("PurchaseRequisitionApprovedBy")
  createdPurchaseOrders PurchaseOrder[] @relation("PurchaseOrderCreatedBy")
  approvedPurchaseOrders PurchaseOrder[] @relation("PurchaseOrderApprovedBy")
  receivedGrns         GoodsReceivedNote[] @relation("GoodsReceivedBy")
  createdSupplierReturns SupplierReturn[] @relation("SupplierReturnCreatedBy")
  createdRecipes       Recipe[]       @relation("RecipeCreatedBy")
  createdProductionPlans ProductionPlan[] @relation("ProductionPlanCreatedBy")
  startedBatches       ProductionBatch[] @relation("ProductionBatchStartedBy")
  closedBatches        ProductionBatch[] @relation("ProductionBatchClosedBy")
  qualityChecks        QualityCheck[] @relation("QualityCheckBy")
  createdCustomers     Customer[]     @relation("CustomerCreatedBy")
  createdQuotations    Quotation[]    @relation("QuotationCreatedBy")
  createdSalesOrders   SalesOrder[]   @relation("SalesOrderCreatedBy")
  deliveredNotes       DeliveryNote[] @relation("DeliveryDeliveredBy")
  createdInvoices      Invoice[]      @relation("InvoiceCreatedBy")
  createdPayments      Payment[]      @relation("PaymentCreatedBy")
  createdCustomerReturns CustomerReturn[] @relation("CustomerReturnCreatedBy")
  servedBranchSales    BranchSale[]   @relation("BranchSaleServedBy")
  approvedBranchExpenses BranchExpense[] @relation("BranchExpenseApprovedBy")
  createdBranchExpenses BranchExpense[] @relation("BranchExpenseCreatedBy")
  closedShiftCloses    BranchShiftClose[] @relation("BranchShiftClosedBy")
  approvedShiftCloses  BranchShiftClose[] @relation("BranchShiftApprovedBy")
  createdPayrollRecords PayrollRecord[] @relation("PayrollCreatedBy")
  createdJournalEntries JournalEntry[] @relation("JournalEntryCreatedBy")
  uploadedFiles        DocumentFile[] @relation("DocumentUploadedBy")
  notifications        Notification[]
  auditLogs            AuditLog[]
  createdStockMovements StockMovement[] @relation("StockMovementCreatedBy")
  requestedTransfers   StockTransfer[] @relation("StockTransferRequestedBy")
  approvedTransfers    StockTransfer[] @relation("StockTransferApprovedBy")
  userAccount          UserAccount?

  @@unique([organizationId, email])
  @@index([organizationId])
  @@index([branchId])
  @@index([status])
  @@index([firstName, lastName])
  @@index([email])
  @@index([deletedAt])
  @@map("user_profiles")
}

model Role {
  id            String           @id @default(uuid()) @db.Uuid
  organizationId String          @db.Uuid @map("organization_id")
  name          String
  description   String?
  isSystemRole  Boolean          @default(false) @map("is_system_role")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")
  organization  Organization     @relation(fields: [organizationId], references: [id])
  permissions   RolePermission[]
  users         UserRole[]
  userAccounts  UserAccount[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([name])
  @@map("roles")
}

model Permission {
  id            String           @id @default(uuid()) @db.Uuid
  code          String           @unique
  name          String
  description   String?
  module        String
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")
  rolePermissions RolePermission[]

  @@index([module])
  @@index([name])
  @@map("permissions")
}

model RolePermission {
  id            String       @id @default(uuid()) @db.Uuid
  roleId        String       @db.Uuid @map("role_id")
  permissionId  String       @db.Uuid @map("permission_id")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  role          Role         @relation(fields: [roleId], references: [id])
  permission    Permission   @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model UserRole {
  id            String       @id @default(uuid()) @db.Uuid
  userProfileId String       @db.Uuid @map("user_profile_id")
  roleId        String       @db.Uuid @map("role_id")
  assignedBy    String?      @db.Uuid @map("assigned_by")
  assignedAt    DateTime     @default(now()) @map("assigned_at")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  userProfile   UserProfile  @relation("UserRoleProfile", fields: [userProfileId], references: [id])
  role          Role         @relation(fields: [roleId], references: [id])
  assignedByUser UserProfile? @relation("UserRoleAssignedBy", fields: [assignedBy], references: [id])

  @@unique([userProfileId, roleId])
  @@index([userProfileId])
  @@index([roleId])
  @@index([assignedBy])
  @@index([assignedAt])
  @@map("user_roles")
}

model UserAccount {
  id                 String          @id @default(uuid()) @db.Uuid
  workId             String          @unique @map("work_id")
  firstName          String          @map("first_name")
  lastName           String          @map("last_name")
  idNumber           String          @unique @map("id_number")
  email              String          @unique
  passwordHash       String          @map("password_hash")
  roleId             String          @db.Uuid @map("role_id")
  role               Role            @relation(fields: [roleId], references: [id])
  organizationId     String          @db.Uuid @map("organization_id")
  organization       Organization    @relation(fields: [organizationId], references: [id])
  userProfileId      String?         @unique @db.Uuid @map("user_profile_id")
  userProfile        UserProfile?    @relation(fields: [userProfileId], references: [id])
  isActive           Boolean         @default(true) @map("is_active")
  failedLoginAttempts Int            @default(0) @map("failed_login_attempts")
  lockedUntil        DateTime?       @map("locked_until")
  lastLogin          DateTime?       @map("last_login")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")
  deletedAt          DateTime?       @map("deleted_at")
  sessions           AuthSession[]
  passwordResetTokens PasswordResetToken[]

  @@index([organizationId])
  @@index([roleId])
  @@index([isActive])
  @@index([deletedAt])
  @@map("user_accounts")
}

model AdminKey {
  id          String    @id @default(uuid()) @db.Uuid
  keyValue    String    @unique @map("key_value")
  description String?
  isActive    Boolean   @default(true) @map("is_active")
  usageCount  Int       @default(0) @map("usage_count")
  maxUsage    Int?      @map("max_usage")
  createdBy   String?   @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  expiresAt   DateTime? @map("expires_at")

  @@index([isActive])
  @@map("admin_keys")
}

model PasswordResetToken {
  id            String       @id @default(uuid()) @db.Uuid
  userAccountId String       @db.Uuid @map("user_account_id")
  userAccount   UserAccount  @relation(fields: [userAccountId], references: [id])
  token         String       @unique
  expiresAt     DateTime     @map("expires_at")
  usedAt        DateTime?    @map("used_at")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  @@index([userAccountId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model AuthSession {
  id            String      @id @default(uuid()) @db.Uuid
  userAccountId String      @db.Uuid @map("user_account_id")
  userAccount   UserAccount @relation(fields: [userAccountId], references: [id])
  token         String      @unique
  ipAddress     String?     @map("ip_address")
  userAgent     String?     @map("user_agent")
  expiresAt     DateTime    @map("expires_at")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  @@index([userAccountId])
  @@index([expiresAt])
  @@map("auth_sessions")
}

model Branch {
  id               String           @id @default(uuid()) @db.Uuid
  organizationId   String           @db.Uuid @map("organization_id")
  code             String
  name             String
  address          String?
  phone            String?
  managerId        String?          @db.Uuid @map("manager_id")
  status           BranchStatus     @default(ACTIVE)
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  deletedAt        DateTime?        @map("deleted_at")
  organization     Organization     @relation(fields: [organizationId], references: [id])
  manager          UserProfile?     @relation("BranchManager", fields: [managerId], references: [id])
  userProfiles     UserProfile[]    @relation("BranchUsers")
  employees        Employee[]
  warehouses       Warehouse[]
  salesOrders      SalesOrder[]
  branchSales      BranchSale[]
  branchExpenses   BranchExpense[]
  branchShiftCloses BranchShiftClose[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([managerId])
  @@index([status])
  @@index([name])
  @@index([deletedAt])
  @@map("branches")
}

model Warehouse {
  id                String            @id @default(uuid()) @db.Uuid
  organizationId    String            @db.Uuid @map("organization_id")
  branchId          String?           @db.Uuid @map("branch_id")
  code              String
  name              String
  type              WarehouseType
  address           String?
  isActive          Boolean           @default(true) @map("is_active")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  organization      Organization      @relation(fields: [organizationId], references: [id])
  branch            Branch?           @relation(fields: [branchId], references: [id])
  inventoryBatches  InventoryBatch[]
  stockBalances     StockBalance[]
  stockMovements    StockMovement[]
  goodsReceivedNotes GoodsReceivedNote[]
  productionBatches ProductionBatch[]
  salesOrders       SalesOrder[]
  fromTransfers     StockTransfer[]   @relation("TransferFromWarehouse")
  toTransfers       StockTransfer[]   @relation("TransferToWarehouse")

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([branchId])
  @@index([type])
  @@index([name])
  @@map("warehouses")
}

model ItemCategory {
  id             String         @id @default(uuid()) @db.Uuid
  organizationId String         @db.Uuid @map("organization_id")
  name           String
  description    String?
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  organization   Organization   @relation(fields: [organizationId], references: [id])
  items          Item[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([name])
  @@map("item_categories")
}

model UnitOfMeasure {
  id             String                  @id @default(uuid()) @db.Uuid
  organizationId String                  @db.Uuid @map("organization_id")
  name           String
  abbreviation   String
  createdAt      DateTime                @default(now()) @map("created_at")
  updatedAt      DateTime                @updatedAt @map("updated_at")
  organization   Organization            @relation(fields: [organizationId], references: [id])
  items          Item[]
  requisitionItems PurchaseRequisitionItem[]
  purchaseOrderItems PurchaseOrderItem[]
  recipesAsOutput Recipe[]               @relation("RecipeOutputUnit")
  recipeItems     RecipeItem[]           @relation("RecipeItemUnit")
  productionBatchMaterials ProductionBatchMaterial[] @relation("ProductionMaterialUnit")
  productionBatchOutputs ProductionBatchOutput[] @relation("ProductionOutputUnit")

  @@unique([organizationId, abbreviation])
  @@index([organizationId])
  @@index([name])
  @@map("units_of_measure")
}

model Item {
  id                String                @id @default(uuid()) @db.Uuid
  organizationId    String                @db.Uuid @map("organization_id")
  code              String
  name              String
  description       String?
  itemType          ItemType              @map("item_type")
  categoryId        String                @db.Uuid @map("category_id")
  unitOfMeasureId   String                @db.Uuid @map("unit_of_measure_id")
  reorderLevel      Decimal?              @db.Decimal(18, 3) @map("reorder_level")
  reorderQuantity   Decimal?              @db.Decimal(18, 3) @map("reorder_quantity")
  unitCost          Decimal?              @db.Decimal(18, 2) @map("unit_cost")
  sellingPrice      Decimal?              @db.Decimal(18, 2) @map("selling_price")
  isActive          Boolean               @default(true) @map("is_active")
  trackExpiry       Boolean               @default(false) @map("track_expiry")
  imageUrl          String?               @map("image_url")
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt @map("updated_at")
  deletedAt         DateTime?             @map("deleted_at")
  organization      Organization          @relation(fields: [organizationId], references: [id])
  category          ItemCategory          @relation(fields: [categoryId], references: [id])
  unitOfMeasure     UnitOfMeasure         @relation(fields: [unitOfMeasureId], references: [id])
  inventoryBatches  InventoryBatch[]
  stockBalances     StockBalance[]
  stockMovements    StockMovement[]
  stockTransferItems StockTransferItem[]
  requisitionItems  PurchaseRequisitionItem[]
  purchaseOrderItems PurchaseOrderItem[]
  grnItems          GoodsReceivedNoteItem[]
  recipeAsFinishedGood Recipe[]          @relation("FinishedItemRecipes")
  recipeMaterials   RecipeItem[]          @relation("RecipeMaterialItem")
  recipeSubstitutions RecipeItem[]        @relation("RecipeSubstituteItem")
  productionBatchMaterials ProductionBatchMaterial[]
  productionBatchOutputs ProductionBatchOutput[]
  quotationItems    QuotationItem[]
  salesOrderItems   SalesOrderItem[]
  invoiceItems      InvoiceItem[]
  branchSaleItems   BranchSaleItem[]

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([categoryId])
  @@index([unitOfMeasureId])
  @@index([itemType])
  @@index([name])
  @@index([isActive])
  @@index([deletedAt])
  @@map("items")
}

model InventoryBatch {
  id                String               @id @default(uuid()) @db.Uuid
  organizationId    String               @db.Uuid @map("organization_id")
  itemId            String               @db.Uuid @map("item_id")
  warehouseId       String               @db.Uuid @map("warehouse_id")
  batchNumber       String               @map("batch_number")
  manufacturedDate  DateTime?            @db.Date @map("manufactured_date")
  expiryDate        DateTime?            @db.Date @map("expiry_date")
  quantityReceived  Decimal              @db.Decimal(18, 3) @map("quantity_received")
  quantityRemaining Decimal              @db.Decimal(18, 3) @map("quantity_remaining")
  unitCost          Decimal              @db.Decimal(18, 2) @map("unit_cost")
  supplierId        String?              @db.Uuid @map("supplier_id")
  status            InventoryBatchStatus @default(ACTIVE)
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")
  organization      Organization         @relation(fields: [organizationId], references: [id])
  item              Item                 @relation(fields: [itemId], references: [id])
  warehouse         Warehouse            @relation(fields: [warehouseId], references: [id])
  supplier          Supplier?            @relation(fields: [supplierId], references: [id])
  stockMovements    StockMovement[]

  @@unique([warehouseId, itemId, batchNumber])
  @@index([organizationId])
  @@index([itemId])
  @@index([warehouseId])
  @@index([supplierId])
  @@index([status])
  @@index([manufacturedDate])
  @@index([expiryDate])
  @@map("inventory_batches")
}

model StockBalance {
  id                String        @id @default(uuid()) @db.Uuid
  organizationId    String        @db.Uuid @map("organization_id")
  itemId            String        @db.Uuid @map("item_id")
  warehouseId       String        @db.Uuid @map("warehouse_id")
  quantityOnHand    Decimal       @db.Decimal(18, 3) @map("quantity_on_hand")
  quantityReserved  Decimal       @db.Decimal(18, 3) @default(0) @map("quantity_reserved")
  quantityAvailable Decimal       @db.Decimal(18, 3) @map("quantity_available")
  lastUpdated       DateTime      @default(now()) @map("last_updated")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  organization      Organization  @relation(fields: [organizationId], references: [id])
  item              Item          @relation(fields: [itemId], references: [id])
  warehouse         Warehouse     @relation(fields: [warehouseId], references: [id])

  @@unique([itemId, warehouseId])
  @@index([organizationId])
  @@index([itemId])
  @@index([warehouseId])
  @@index([lastUpdated])
  @@map("stock_balances")
}

model StockMovement {
  id             String             @id @default(uuid()) @db.Uuid
  organizationId String             @db.Uuid @map("organization_id")
  itemId         String             @db.Uuid @map("item_id")
  warehouseId    String             @db.Uuid @map("warehouse_id")
  movementType   StockMovementType  @map("movement_type")
  quantity       Decimal            @db.Decimal(18, 3)
  unitCost       Decimal?           @db.Decimal(18, 2) @map("unit_cost")
  totalCost      Decimal?           @db.Decimal(18, 2) @map("total_cost")
  runningBalance Decimal?           @db.Decimal(18, 3) @map("running_balance")
